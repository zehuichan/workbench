{
  "name": "@labs/ant-table",
  "version": "0.0.0",
  "private": true,
  "description": "基于 Ant Design Vue a-table 的增强表格组件 AntTable",
  "type": "module",
  "main": "./src/index.ts",
  "module": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./styles": "./src/styles/index.scss",
    "./package.json": "./package.json"
  },
  "sideEffects": [
    "*.scss",
    "*.css"
  ],
  "scripts": {
    "typecheck": "vue-tsc --noEmit -p tsconfig.json"
  },
  "peerDependencies": {
    "ant-design-vue": "^4.0.0",
    "vue": "^3.4.0"
  },
  "dependencies": {
    "@vue/shared": "catalog:",
    "@vueuse/core": "catalog:",
    "async-validator": "catalog:",
    "es-toolkit": "catalog:"
  },
  "devDependencies": {
    "ant-design-vue": "catalog:",
    "typescript": "catalog:",
    "vue": "catalog:",
    "vue-tsc": "catalog:"
  }
}
