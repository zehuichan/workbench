{
  "$schema": "https://turbo.build/schema.json",
  "globalEnv": ["VITE_PORT", "VITE_BASE"],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "inputs": ["$TURBO_DEFAULT$", ".env*"],
      "outputs": ["dist/**", ".vitepress/dist/**"]
    },
    "typecheck": {
      "dependsOn": ["^typecheck"],
      "inputs": [
        "src/**",
        ".vitepress/**",
        "**/demo/**/*.vue",
        "tsconfig*.json"
      ]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "preview": {
      "cache": false,
      "persistent": true
    },
    "clean": {
      "cache": false
    }
  }
}
